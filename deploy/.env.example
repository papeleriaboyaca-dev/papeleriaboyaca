# ============================================================
# Papelería Boyacá v2 — Variables de entorno
# Copiar como deploy/.env y completar los valores reales.
# NUNCA subir deploy/.env al repositorio.
# ============================================================

# ── Entorno ─────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# ── Supabase ────────────────────────────────────────────────
# URL del proyecto: https://<ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# anon key (public) — usada por el identity-service para operaciones de cliente
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret del proyecto (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Base de datos ────────────────────────────────────────────
# Usar Session Pooler (puerto 6543), NO Transaction Pooler (5432)
# Formato: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Wompi ────────────────────────────────────────────────────
# Para sandbox: https://sandbox.wompi.co/v1
# Para producción: https://production.wompi.co/v1
WOMPI_API_URL=https://sandbox.wompi.co/v1

# Claves del comercio (Panel Wompi → Desarrolladores)
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_PUBLIC_KEY=pub_test_...

# Secretos de eventos e integridad (Panel Wompi → Eventos)
WOMPI_EVENTS_SECRET=test_events_...
WOMPI_INTEGRITY_SECRET=test_integrity_...

# true para sandbox, false para producción con dinero real
WOMPI_TEST_MODE=true

# ── URLs de la aplicación ─────────────────────────────────────
# URL pública del API Gateway (con dominio, sin trailing slash)
APP_URL=https://api.tudominio.com

# URL pública del frontend
FRONTEND_URL=https://tudominio.com

# Dominio para Caddy (TLS automático) — solo si usas --profile caddy
APP_DOMAIN=tudominio.com

# ── Auth interna entre microservicios ────────────────────────
# Shared secret usado en el header X-Internal-Auth. El gateway lo inyecta;
# cada microservicio lo valida en su middleware.
# Generar con: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Cleanup de órdenes huérfanas (job en background del order-service) ──
# Cancela órdenes en pending > N minutos para liberar stock reservado.
ORDER_CLEANUP_ENABLED=true
ORDER_CLEANUP_TIMEOUT_MINUTES=60
ORDER_CLEANUP_INTERVAL_SECONDS=300

# ── Redis (solo si usas --profile optional) ──────────────────
REDIS_PASSWORD=change-this-in-production
